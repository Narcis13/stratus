# Register an app in console.x.com (use Production environment, not Development).
# OAuth redirect URI MUST match exactly — use 127.0.0.1 not localhost.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/auth/x/callback

# Optional — app-only Bearer token, for public reads without user auth.
X_BEARER_TOKEN=

# Your own numeric X user id (from getMe). Required by the publisher and the
# daily metrics worker — createPost refuses replies without it (Feb 2026 policy).
SELF_X_USER_ID=

# xAI API key — Grok-backed surfaces (/grok/ask, /x/replies/*). Those routers
# refuse to mount when unset.
XAI_API_KEY=

# Set to 'false' to disable the daily 03:00 UTC metrics timer (manual
# POST /x/posts/reconcile still works). Any other value (or unset) = enabled.
DAILY_METRICS_ENABLED=true

# Soft daily X budget in USD — crossing it logs a loud BUDGET WATCHDOG error and
# flags /cost/today; never blocks calls. Default 0.15.
X_DAILY_BUDGET_USD=0.15

# Base URL the stratus skill (and any CLI scripts) targets. Defaults to
# http://127.0.0.1:3000 when unset. Point at the deployed instance otherwise.
# No trailing slash.
STRATUS_BASE_URL=

PORT=3000

# Bearer token shared by the API and the Chrome extension. One secret, one user.
# Generate with e.g. `openssl rand -hex 32`.
API_TOKEN=

# Neon Postgres connection string (use the non-pooled URL for drizzle-kit migrations;
# the runtime app uses the same URL — neon-serverless WebSocket Pool handles pooling).
DATABASE_URL=

# Optional — extra CORS origins beyond chrome-extension://* (e.g. a deployed UI).
# Comma-separated, exact match. The unpacked Chrome extension is always allowed.
ALLOWED_ORIGINS=
