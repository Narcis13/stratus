{
  "name": "stratus",
  "version": "0.1.1",
  "private": true,
  "description": "Thin typed wrapper over X API v2. Companion to X-API-IMPLEMENTATION-PLAN.md.",
  "type": "module",
  "scripts": {
    "start": "bun run src/app.ts",
    "auth": "bun run src/x/server.ts",
    "play": "bun run src/x/playground.ts",
    "test": "SQLITE_PATH=:memory: bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18"
  }
}
